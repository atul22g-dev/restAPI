<!DOCTYPE html>
<html lang="en">
<head>
  <title>ProductAPI - Manage Products</title>
  {{> _head}}
</head>
<body>
  {{> _navbar}}

  <div class="container">
    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between mb-4 animate-fade-up">        <div class="d-flex align-items-center gap-3">
        <div class="icon-box icon-box-primary">
          <i class="fa-solid fa-table"></i>
        </div>
        <div>
          <h3 class="fw-bold mb-1">Manage Products</h3>
          <p class="text-muted mb-0">View, edit, and delete your products</p>
        </div>
      </div>
      <a href="/create" class="btn btn-gradient d-none d-md-flex">
        <i class="fa-solid fa-plus me-2"></i>Add Product
      </a>
    </div>

    <!-- Products Table Card -->
    <div class="modern-card p-3 p-lg-4 animate-fade-up animate-delay-1">
      <div class="table-responsive">
        <table class="modern-table" id="productsTable">
          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Price</th>
              <th>Company</th>
              <th>Rating</th>
              <th>Featured</th>
              <th style="width: 120px;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {{#each Products}}
            <tr data-id="{{ _id }}">
              <td class="fw-semibold text-muted">{{ @index }}</td>
              <td class="fw-semibold">{{ name }}</td>
              <td class="fw-bold text-color-price">${{ price }}</td>
              <td>
                <span class="company-badge company-{{ company }}">
                  <i class="fa-solid fa-building"></i> {{ company }}
                </span>
              </td>
              <td>
                <div class="stars" data-rating="{{ rating }}">
                  <span class="text-color-muted" style="font-size: 0.8rem;">({{ rating }})</span>
                </div>
              </td>
              <td>
                {{#if featured}}
                  <span class="featured-badge featured-yes"><i class="fa-solid fa-check me-1"></i>Yes</span>
                {{else}}
                  <span class="featured-badge featured-no"><i class="fa-solid fa-xmark me-1"></i>No</span>
                {{/if}}
              </td>
              <td>
                <div class="d-flex gap-2">
                  <button class="action-btn action-btn-edit" onclick="editProduct('{{ _id }}')" title="Edit">
                    <i class="fa-solid fa-pen"></i>
                  </button>
                  <button class="action-btn action-btn-delete" onclick="deleteProduct('{{ _id }}')" title="Delete">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                  <a href="/api/products/{{ _id }}" target="_blank" class="action-btn action-btn-view" title="View JSON">
                    <i class="fa-solid fa-code"></i>
                  </a>
                </div>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      {{#unless Products.length}}
      <div class="text-center py-5">
        <i class="fa-solid fa-box-open mb-3 text-color-empty" style="font-size: 3rem;"></i>
        <h5 class="text-muted">No products yet</h5>
        <p class="text-muted small">Click "Add Product" to create your first product</p>
        <a href="/create" class="btn btn-gradient mt-2">
          <i class="fa-solid fa-plus me-2"></i>Add Product
        </a>
      </div>
      {{/unless}}
    </div>
  </div>

  <!-- Edit Modal -->
  <div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title fw-bold">
            <i class="fa-solid fa-pen me-2 text-color-primary"></i>
            Edit Product
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <form id="editForm">
            <input type="hidden" id="editId">
            <div class="mb-3">
              <label class="form-label fw-semibold">Product Name <span class="text-color-danger">*</span></label>
              <input type="text" class="form-control modern-input" id="editName" required minlength="2">
            </div>
            <div class="mb-3">
              <label class="form-label fw-semibold">Price <span class="text-color-danger">*</span></label>
              <input type="number" class="form-control modern-input" id="editPrice" required min="0" step="0.01">
            </div>
            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold">Company <span class="text-color-danger">*</span></label>
                <select class="form-select modern-input" id="editCompany" required>
                  <option value="apple">Apple</option>
                  <option value="samsung">Samsung</option>
                  <option value="dell">Dell</option>
                  <option value="mi">MI</option>
                  <option value="asus">ASUS</option>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Rating</label>
                <input type="number" class="form-control modern-input" id="editRating" min="0" max="5" step="0.1">
              </div>
            </div>
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="editFeatured" style="width: 3rem; height: 1.5rem; cursor: pointer;">
              <label class="form-check-label fw-semibold" for="editFeatured">
                <i class="fa-solid fa-star me-1 text-color-star"></i> Featured Product
              </label>
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius: 10px;">Cancel</button>
          <button type="button" class="btn btn-gradient" id="saveEditBtn">
            <i class="fa-solid fa-save me-2"></i>Save Changes
          </button>
        </div>
      </div>
    </div>
  </div>

  {{> _footer}}

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Render star ratings
      document.querySelectorAll('.stars').forEach(function(el) {
        var rating = parseFloat(el.getAttribute('data-rating')) || 0;
        var fullStars = Math.floor(rating);
        var html = '';
        for (var i = 0; i < fullStars; i++) {
          html += '<i class="fa-solid fa-star"></i>';
        }
        for (var i = fullStars; i < 5; i++) {
          html += '<i class="fa-solid fa-star empty"></i>';
        }
        html += ' <span class="text-color-muted" style="font-size: 0.8rem;">(' + rating + ')</span>';
        el.innerHTML = html;
      });
    });

    function getRowData(id) {
      var row = document.querySelector('tr[data-id="' + id + '"]');
      if (!row) return null;
      var cells = row.querySelectorAll('td');
      return {
        name: cells[1].textContent.trim(),
        price: parseFloat(cells[2].textContent.replace('$', '')),
        company: cells[3].querySelector('.company-badge') ? cells[3].querySelector('.company-badge').textContent.trim() : '',
        rating: cells[4].querySelector('[data-rating]') ? parseFloat(cells[4].querySelector('[data-rating]').getAttribute('data-rating')) : 0,
        featured: cells[5].querySelector('.featured-yes') !== null,
      };
    }

    function editProduct(id) {
      var data = getRowData(id);
      if (!data) return;
      document.getElementById('editId').value = id;
      document.getElementById('editName').value = data.name;
      document.getElementById('editPrice').value = data.price;
      document.getElementById('editCompany').value = data.company;
      document.getElementById('editRating').value = data.rating;
      document.getElementById('editFeatured').checked = data.featured;
      var modal = new bootstrap.Modal(document.getElementById('editModal'));
      modal.show();
    }

    var saveBtn = document.getElementById('saveEditBtn');
    if (saveBtn) {
      saveBtn.addEventListener('click', async function() {
        var id = document.getElementById('editId').value;
        var name = document.getElementById('editName').value.trim();
        var price = document.getElementById('editPrice').value;
        var company = document.getElementById('editCompany').value;
        var rating = document.getElementById('editRating').value;
        var featured = document.getElementById('editFeatured').checked;
        if (!name || !price || !company) {
          showToast('warning', 'Validation', 'Please fill in all required fields');
          return;
        }
        var btn = this;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';
        try {
          var response = await fetch('/api/products/' + id, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: name, price: parseFloat(price), company: company,
              rating: rating ? parseFloat(rating) : undefined, featured: featured,
            }),
          });
          var result = await response.json();
          if (response.ok) {
            showToast('success', 'Updated!', 'Product updated successfully');
            setTimeout(function() { location.reload(); }, 1200);
          } else {
            showToast('error', 'Error!', result.message || 'Failed to update product');
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-save me-2"></i>Save Changes';
          }
        } catch (err) {
          showToast('error', 'Error!', 'Network error. Please try again.');
          btn.disabled = false;
          btn.innerHTML = '<i class="fa-solid fa-save me-2"></i>Save Changes';
        }
      });
    }

    function deleteProduct(id) {
      Swal.fire({
        title: 'Delete Product?',
        text: 'This action cannot be undone!',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: '<i class="fa-solid fa-trash me-2"></i>Delete',
        cancelButtonText: 'Cancel',
        reverseButtons: true,
      }).then(async function(result) {
        if (result.isConfirmed) {
          try {
            var response = await fetch('/api/products/' + id, { method: 'DELETE' });
            var data = await response.json();
            if (response.ok) {
              Swal.fire({ icon: 'success', title: 'Deleted!', text: 'Product has been deleted.', timer: 1500, showConfirmButton: false });
              setTimeout(function() { location.reload(); }, 1200);
            } else {
              showToast('error', 'Error!', data.message || 'Failed to delete product');
            }
          } catch (err) {
            showToast('error', 'Error!', 'Network error. Please try again.');
          }
        }
      });
    }

    $(document).ready(function() {
      if ($('#productsTable tbody tr').length > 0) {
        $('#productsTable').DataTable({
          responsive: true,
          pageLength: 10,
          language: { search: '<i class="fa-solid fa-search me-1"></i> Search:', searchPlaceholder: 'Type to filter...' },
          columnDefs: [{ orderable: false, targets: 6 }],
        });
      }
    });
  </script>
</body>
</html>
