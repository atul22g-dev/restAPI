<!DOCTYPE html>
<html lang="en">
<head>
  <title>404 - Page Not Found | ProductAPI</title>
  {{> _head}}
  <style>
    .error-container {
      min-height: calc(100vh - 80px);
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
    }
    .error-code {
      font-size: 8rem;
      font-weight: 900;
      background: linear-gradient(135deg, #0d6efd, #6f42c1);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1;
      margin-bottom: 0;
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }
    .error-divider {
      width: 80px;
      height: 4px;
      background: linear-gradient(135deg, #0d6efd, #6f42c1);
      border-radius: 4px;
      margin: 1.5rem auto;
    }
    .error-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }
    .error-message {
      color: var(--text-secondary);
      max-width: 400px;
      margin: 0 auto 2rem;
    }
    .error-path {
      display: inline-block;
      background: var(--code-bg);
      padding: 0.3rem 0.8rem;
      border-radius: 8px;
      font-family: 'Courier New', monospace;
      font-size: 0.85rem;
      color: #dc3545;
      margin-bottom: 1.5rem;
      word-break: break-all;
      max-width: 100%;
    }
    .error-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    :root[data-theme="dark"] .error-path {
      background: #2d2d4a;
    }
  </style>
</head>
<body>
  {{> _navbar}}

  <div class="container">
    <div class="error-container animate-fade-up">
      <div>
        <p class="error-code">404</p>
        <div class="error-divider"></div>
        <h2 class="error-title">Page Not Found</h2>
        <p class="error-message">
          The page you're looking for doesn't exist or has been moved.
        </p>
        <div class="error-path">{{ url }}</div>
        <div class="error-actions">
          <a href="/" class="btn btn-gradient">
            <i class="fa-solid fa-house me-2"></i>Go Home
          </a>
          <a href="/api/products" class="btn btn-outline-gradient">
            <i class="fa-solid fa-list me-2"></i>Browse Products
          </a>
          <a href="/api/docs" class="btn btn-outline-gradient">
            <i class="fa-solid fa-book me-2"></i>API Docs
          </a>
        </div>
      </div>
    </div>
  </div>

  {{> _footer}}
</body>
</html>
